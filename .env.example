# Servidor
PORT=3000
NODE_ENV=production
BASE_URL=https://checkin.angatu.com.br

# Tablet Cloud API
TABLETCLOUD_BASE_URL=https://api.tabletcloud.com.br
TABLETCLOUD_LOGIN=SEU_LOGIN
TABLETCLOUD_SENHA=SUA_SENHA
TABLETCLOUD_COD_EMPRESA=SEU_COD_EMPRESA
TABLETCLOUD_SENHA_EMPRESA=SUA_SENHA_EMPRESA

# n8n Webhooks
N8N_WEBHOOK_CHECKIN=https://n8n.suaagencia.com.br/webhook/angatu-checkin
N8N_WEBHOOK_SECRET=SEU_SECRET

# SQLite
DB_PATH=./database/angatu.db

# Rate limit
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30

# CORS — domínios autorizados (separados por vírgula)
ALLOWED_ORIGINS=http://localhost:3000,https://checkin.angatu.com.br
