# Servidor
PORT=3000
NODE_ENV=production
BASE_URL=https://checkin.inframb4.com

# Tablet Cloud API — credenciais OAuth do PDV
TABLETCLOUD_BASE_URL=https://api.tabletcloud.com.br
TABLETCLOUD_USERNAME=seu_email@gmail.com
TABLETCLOUD_PASSWORD=sua_senha
TABLETCLOUD_CLIENT_ID=seu_client_id
TABLETCLOUD_CLIENT_SECRET=seu_client_secret

# n8n Webhooks
N8N_WEBHOOK_CHECKIN=https://n8n.inframb4.com/webhook/angatu-checkin
N8N_WEBHOOK_SECRET=SEU_SECRET

# SQLite
DB_PATH=./database/angatu.db

# Rate limit
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30

# CORS — domínios autorizados (separados por vírgula)
ALLOWED_ORIGINS=http://localhost:3000,https://checkin.inframb4.com
